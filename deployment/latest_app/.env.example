# AttieLab-QTL-Viewer environment configuration template.
# Copy this file to `.env` at the repo root and fill in your real values.
#   cp deployment/latest_app/.env.example .env
# DO NOT commit .env to git (.gitignore excludes it).

# =============================================================================
# S3-compatible object storage (AWS, MinIO, Ceph, on-prem, etc.)
# =============================================================================
# Full HTTPS URL of the S3 endpoint. For real AWS leave empty (paws picks
# the regional default). For MinIO/Ceph/on-prem set to e.g.
# https://s3.example.org.
QTLAPP_S3_ENDPOINT=https://<your-s3-endpoint>

# Bucket name (no s3://, no slashes).
QTLAPP_S3_BUCKET=<your-bucket-name>

# Prefix (sub-path) inside the bucket where the data lives. Trailing slash
# is fine; leave empty if data is at the bucket root.
QTLAPP_S3_PREFIX=<your-prefix>/

# Region. Most on-prem S3s ignore this but paws requires a non-empty value.
QTLAPP_S3_REGION=us-east-1

# Path-style addressing. Required for MinIO/Ceph/on-prem (URL pattern is
# https://endpoint/bucket/key). Safe to leave TRUE for real AWS too.
QTLAPP_S3_FORCE_PATH_STYLE=true

# =============================================================================
# Credentials (KEEP SECRET — never commit these)
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# =============================================================================
# Caching
# =============================================================================
# Maximum on-disk cache size before LRU eviction kicks in.
QTLAPP_CACHE_MAX_GB=20

# ETag freshness check:
#   never     = serve cached forever (fastest; restart to pick up changes)
#   on_stale  = HEAD only if cache entry older than QTLAPP_ETAG_CHECK_TTL_SECONDS
#   always    = HEAD on every access (slowest; strongest consistency)
QTLAPP_ETAG_CHECK_MODE=never

# How many parallel R workers to use for I/O-bound S3 prefetch.
QTLAPP_FUTURE_WORKERS=8

# =============================================================================
# Launch-script options (optional — defaults are fine for most cases)
# =============================================================================
# HOST_PORT=3838
# HOST_CACHE_DIR=/home/youruser/qtl_viewer_cache
# CONTAINER_NAME=qtl-viewer
# IMAGE_NAME=qtl-viewer:latest
